<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="abes">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.abes.entity.Dept</class>
        <properties>

            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5433/abes"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.user" value="aaditya"/>
            <property name="jakarta.persistence.jdbc.password" value="1111"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>

        </properties>

    </persistence-unit>

</persistence>